go-module_set_globals

SRC_URI="https://github.com/ko-build/${PN}/archive/v${PV}.tar.gz -> ${P}.tar.gz
	${EGO_SUM_SRC_URI}"

LICENSE="Apache-2.0 BSD BSD-2 ISC MIT MPL-2.0"
SLOT="0"
KEYWORDS="~amd64"
RESTRICT="mirror strip"

BDEPEND=">=dev-lang/go-1.26.3:="

src_compile() {
	local -x CGO_ENABLED=0
	local ldflags=(
		-s
		-w
		-X github.com/google/ko/pkg/commands.Version=${PV}
	)

	ego build -trimpath -ldflags "${ldflags[*]}" -o ${PN} ./main.go

	einfo "generating shell completion files"
	sysroot_try_run_prefixed ./${PN} completion bash > ${PN}.bash || die
	sysroot_try_run_prefixed ./${PN} completion zsh > ${PN}.zsh || die
	sysroot_try_run_prefixed ./${PN} completion fish > ${PN}.fish || die
}

src_test() {
	# Portage's go-env exports GOOS/GOARCH, but upstream rejects them when
	# tests explicitly set Platforms: all.
	unset GOOS GOARCH GOARM
	ego test ./... -skip "TestNewPublisherCanPublish/bare_with_local_domain_and_repo"
}

src_install() {
	dobin ${PN}
	dodoc CONTRIBUTING.md README.md ROADMAP.md

	newbashcomp ${PN}.bash ${PN}
	newzshcomp ${PN}.zsh _${PN}
	dofishcomp ${PN}.fish
}
